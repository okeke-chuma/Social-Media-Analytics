   "outputs": [],
   "source": [
    "# Define query as English tweets that match the keyword 'covid' and is not a retweet\n",
    "query = 'covid -is:retweet lang:en'\n",
    "\n",
    "# get max. 100 tweets\n",
    "tweets = client.search_recent_tweets(query=query, \n",
    "                                    tweet_fields=['author_id', 'text','created_at','public_metrics'],  \n",
    "                                    max_results=100)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "c6ae6ed4",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save data as dictionary\n",
    "tweets_dict = tweets.json() \n",
    "\n",
    "# Extract \"data\" value from dictionary\n",
    "tweets_data = tweets_dict['data'] \n",
    "\n",
    "# Transform to pandas Dataframe\n",
    "tweets_df = pd.json_normalize(tweets_data) "
   ]
  },
