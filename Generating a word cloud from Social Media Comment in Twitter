   "outputs": [],
   "source": [
    "# Load in the dataframe\n",
    "# You can use this command to load other data in Excel\n",
    "tweets_df = pd.read_excel(\"COVID tweets.xlsx\", header=0)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "30aa26d5",
   "metadata": {},
   "outputs": [],
   "source": [
    "tweets_df #Display the data frame"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "77ce8a91",
   "metadata": {},
   "outputs": [],
   "source": [
    "# For more details on generating the word cloud, see https://www.datacamp.com/tutorial/wordcloud-python\n",
    "\n",
    "text = \" \".join(review for review in tweets_df.text)\n",
    "print (\"There are {} words in the combination of all review.\".format(len(text)))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b8cdb946",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create stopword list:\n",
    "stopwords = set(STOPWORDS)\n",
    "\n",
    "# Generate a word cloud image\n",
    "wordcloud = WordCloud(stopwords=stopwords, background_color=\"white\", width=800, height=400).generate(text)\n",
    "\n",
    "# Display the generated image:\n",
    "# the matplotlib way:\n",
    "plt.figure( figsize=(20,10) )\n",
    "plt.imshow(wordcloud, interpolation='bilinear')\n",
    "plt.axis(\"off\")\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "a1dc77a9",
   "metadata": {},
   "outputs": [],
   "source": [
    "# For more on how to generate a word cloud based on an image, see https://www.geeksforgeeks.org/generate-word-clouds-of-any-shape-in-python/\n",
    "\n",
    "# The Image shape in which you wanna convert it to\n",
    "mask = np.array(Image.open(r'Twitter.png'))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1dcb2fa8",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Now inside the WordCloud, provide some functions:\n",
    "# stopwords - For stop word removal\n",
    "# like [,?/\\\"]\n",
    "# font_path - provide the font path to which you\n",
    "# wanna convert it to.\n",
    "# max_words - Maximum number of words in the\n",
    "# output image. Also provide height and width\n",
    "# of the mask\n",
    "wc = WordCloud(stopwords = STOPWORDS,\n",
    "               mask = mask,\n",
    "               background_color = \"white\",\n",
    "               max_words = 2000,\n",
    "               max_font_size = 500,\n",
    "               random_state = 42,\n",
    "               width = mask.shape[1],\n",
    "               height = mask.shape[0])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "6332addf",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Finally generate the wordcloud of the given text\n",
    "wc.generate(text) \n",
    "plt.figure( figsize=(20,10) )\n",
    "plt.imshow(wc, interpolation = \"None\")\n",
    " \n",
    "# Off the x and y axis\n",
    "plt.axis('off')\n",
    "\n",
    "# Now show the output cloud\n",
    "plt.show()"
   ]
