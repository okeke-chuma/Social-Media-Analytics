   "outputs": [],
   "source": [
    "# Create Tweepy connection client\n",
    "client = tweepy.Client( bearer_token=bearer_token, \n",
    "                        consumer_key=consumer_key, \n",
    "                        consumer_secret=secret_key, \n",
    "                        return_type = requests.Response,\n",
